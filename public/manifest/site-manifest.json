  "workflows": [
    {
      "workflow_id": "browse_and_add_to_cart",
      "name": "Browse pickles and add items to cart",
      "intent_hints": ["browse pickles", "add to cart", "shop pickles", "buy pickle", "pickles"],
      "routes": ["home", "veg_pickles", "non_veg_pickles", "product_detail"],
      "steps": [
        {
          "step_id": "open_product",
          "description": "Open a product or category page",
          "actions": [
            {
              "action_id": "click_product_entry",
              "kind": "click",
              "label": "Open product or category",
              "target_texts": ["Shop veg pickles", "Non-veg range", "Veg", "Non-Veg", "Product card"],
              "route_id": "home",
              "element_id": "product_card",
              "wait_after_ms": 250
            }
          ]
        },
        {
          "step_id": "select_size",
          "description": "Choose a size when the product detail page is visible",
          "actions": [
            {
              "action_id": "choose_size",
              "kind": "click",
              "label": "Select size",
              "target_texts": ["Select size", "Size"],
              "element_id": "size_select",
              "route_id": "product_detail",
              "wait_after_ms": 200
            }
          ]
        },
        {
          "step_id": "add_to_cart",
          "description": "Add item to cart",
          "actions": [
            {
              "action_id": "click_add_to_cart",
              "kind": "click",
              "label": "Add to cart",
              "target_texts": ["Add to cart"],
              "element_id": "add_to_cart",
              "route_id": "product_detail",
              "wait_after_ms": 300
            }
          ]
        }
      ]
    },
    {
      "workflow_id": "review_cart_and_checkout",
      "name": "Review cart and go to checkout",
      "intent_hints": ["review cart", "checkout", "proceed to checkout", "cart"],
      "routes": ["cart", "checkout"],
      "steps": [
        {
          "step_id": "open_cart",
          "description": "Open the cart",
          "actions": [
            {
              "action_id": "open_cart_page",
              "kind": "click",
              "label": "Cart",
              "target_texts": ["Cart"],
              "element_id": "cart_button",
              "route_id": "cart",
              "wait_after_ms": 200
            }
          ]
        },
        {
          "step_id": "proceed_checkout",
          "description": "Proceed from cart to checkout",
          "actions": [
            {
              "action_id": "click_proceed_to_checkout",
              "kind": "click",
              "label": "Proceed to checkout",
              "target_texts": ["Proceed to checkout"],
              "element_id": "proceed_to_checkout",
              "route_id": "cart",
              "wait_after_ms": 350
            }
          ]
        }
      ]
    },
    {
      "workflow_id": "checkout_and_payment",
      "name": "Checkout and start payment",
      "intent_hints": ["fill shipping details", "start payment", "place order", "checkout"],
      "routes": ["checkout"],
      "steps": [
        {
          "step_id": "reach_checkout",
          "description": "Reach the checkout page",
          "actions": [
            {
              "action_id": "open_checkout",
              "kind": "click",
              "label": "Proceed to checkout",
              "target_texts": ["Proceed to checkout", "Checkout"],
              "element_id": "proceed_to_checkout",
              "route_id": "checkout",
              "wait_after_ms": 300
            }
          ]
        },
        {
          "step_id": "pause_for_payment",
          "description": "Hand back to the user for Razorpay payment",
          "requires_human": true,
          "actions": [
            {
              "action_id": "pay_with_razorpay",
              "kind": "pause",
              "label": "Pay with Razorpay",
              "target_texts": ["Pay with Razorpay"],
              "element_id": "pay_with_razorpay",
              "route_id": "checkout",
              "requires_human": true,
              "human_handoff_message": "Please complete shipping details and payment manually in Razorpay.",
              "wait_after_ms": 0
            }
          ]
        }
      ]
    },
    {
      "workflow_id": "order_confirmation",
      "name": "Confirm order after payment",
      "intent_hints": ["order confirmed", "read success page", "receipt", "thank you"],
      "routes": ["checkout_success"],
      "steps": [
        {
          "step_id": "inspect_success_page",
          "description": "Read the success page and verify order completion",
          "actions": [
            {
              "action_id": "read_success_page",
              "kind": "wait",
              "label": "Read the order confirmation page",
              "target_texts": ["Order confirmed", "Thank you", "Download receipt"],
              "element_id": "order_confirmed",
              "route_id": "checkout_success",
              "success_hints": ["Order confirmed", "Order "],
              "wait_after_ms": 800
            }
          ]
        }
      ]
    },
    {
      "workflow_id": "combo_enquiry",
      "name": "Combo enquiry",
      "intent_hints": ["combo enquiry", "combo order", "contact about combo", "combos"],
      "routes": ["combos", "contact"],
      "steps": [
        {
          "step_id": "open_combo_page",
          "description": "Open the combo page",
          "actions": [
            {
              "action_id": "open_combo",
              "kind": "click",
              "label": "Order this combo",
              "target_texts": ["Order this combo"],
              "element_id": "order_this_combo",
              "route_id": "combos",
              "wait_after_ms": 250
            }
          ]
        },
        {
          "step_id": "hand_back_contact",
          "description": "Pause on the contact page so the user can call, email, or WhatsApp",
          "requires_human": true,
          "actions": [
            {
              "action_id": "pause_on_contact",
              "kind": "pause",
              "label": "Continue via contact options",
              "target_texts": ["Get in touch", "phone", "email"],
              "element_id": "contact_phone",
              "route_id": "contact",
              "requires_human": true,
              "human_handoff_message": "Please continue with the contact options on this page.",
              "wait_after_ms": 0
            }
          ]
        }
      ]
    },
    {
      "workflow_id": "whatsapp_support",
      "name": "Open WhatsApp support",
      "intent_hints": ["whatsapp support", "chat on whatsapp", "support", "contact whatsapp"],
      "routes": ["home", "contact"],
      "steps": [
        {
          "step_id": "open_whatsapp",
          "description": "Open the WhatsApp support button",
          "actions": [
            {
              "action_id": "click_whatsapp_support",
              "kind": "click",
              "label": "Chat on WhatsApp",
              "target_texts": ["Chat on WhatsApp"],
              "element_id": "whatsapp_support",
              "route_id": "home",
              "requires_human": true,
              "human_handoff_message": "WhatsApp support should continue in the external app.",
              "wait_after_ms": 200
            }
          ]
        }
      ]
    }
  ],
  "sensitive_keywords": ["otp", "password", "payment", "delete", "confirm", "razorpay"],
  "restricted_actions": ["pay_with_razorpay"],
  "notes": "Lachava pickles client manifest for a stack-agnostic website-owned agent."
}
