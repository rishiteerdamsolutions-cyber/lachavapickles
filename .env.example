# Copy to .env.local for local dev (never commit .env.local)

# Required for /admin login
ADMIN_USERNAME=lachava
ADMIN_PASSWORD=change-this-password
SESSION_SECRET=use-a-long-random-string-here

# Razorpay checkout
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_secret

# Optional — persist orders & products
MONGODB_URI=mongodb+srv://...

# DTDC shipment WhatsApp
NEXT_PUBLIC_DTDC_WHATSAPP_NUMBER=919949525111

# Public site URL (Open Graph)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
